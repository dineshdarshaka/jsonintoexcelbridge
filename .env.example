# .env.example — copy this to .env and fill in your real secrets
# ====================================================================

# Shared secret for API authentication (any long, random string)
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here

# Fernet key for payload encryption (see guide below)
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# CORS — comma-separated origins allowed to call the bridge
ALLOWED_ORIGINS=http://localhost:3000

# Path to the Excel file (absolute or relative to project root)
EXCEL_FILE_PATH=data.xlsx

# Excel sheet name to read/write
EXCEL_SHEET_NAME=Sheet1

# Server bind address and port
HOST=127.0.0.1
PORT=8000
