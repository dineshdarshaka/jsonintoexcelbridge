# .env.example — copy this to .env and fill in your real secrets
# ====================================================================

# Shared secret for API authentication (any long, random string)
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here

# Fernet key for payload encryption (see guide below)
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# CORS — comma-separated origins allowed to call the bridge
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Directory where office-specific Excel workbooks are stored.
# Each office gets its own file:  {EXCEL_DIR}/{office}.xlsx
EXCEL_DIR=data

# Server bind address and port
HOST=127.0.0.1
PORT=8000
